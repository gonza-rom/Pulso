---
const navLinks = [
  { label: "Performance", href: "#", active: true },
  { label: "Intelligence", href: "#" },
  { label: "Coaching", href: "#" },
  { label: "Pricing", href: "#" },
];
---

<header
  class="sticky top-0 w-full z-50 bg-black/10 backdrop-blur-xl border-b border-white/5 shadow-[0_0_20px_rgba(143,214,255,0.1)] transition-all duration-300 py-4"
>
  <div
    class="max-w-7xl mx-auto flex items-center justify-between px-6"
  >
    <div
      class="font-display text-2xl font-extrabold tracking-tighter text-primary flex items-center gap-2"
    >
      PULSO
      <span class="material-symbols-outlined text-primary">pulse_alert</span>
    </div>

    <nav class="hidden md:flex items-center gap-8">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class={
              link.active
                ? "text-xs font-semibold tracking-widest uppercase text-primary border-b-2 border-primary pb-1"
                : "text-xs font-semibold tracking-widest uppercase text-white/50 hover:text-white transition-colors duration-300"
            }
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-6">
      <button
        class="hidden sm:block text-xs font-semibold tracking-widest uppercase text-white hover:text-primary transition-all duration-300"
      >
        Login
      </button>
      <button
        class="bg-primary text-black px-4 py-2 rounded-full text-xs font-semibold tracking-widest uppercase hover:scale-105 active:scale-95 transition-all duration-300 shadow-[0_0_20px_rgba(143,214,255,0.2)]"
      >
        Start Training
      </button>
    </div>
  </div>
</header>