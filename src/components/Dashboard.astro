---
const checkItems = [
  "Monitoreo de Carga Semanal",
  "Métricas de Energía Vital",
  "Widgets personalizables",
];
---

<section class="py-24 relative overflow-hidden">
  <div
    class="absolute top-0 right-0 w-1/2 h-full bg-primary/5 blur-3xl rounded-full"
  >
  </div>

  <div class="max-w-7xl mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <!-- Left: Text -->
      <div class="space-y-8 reveal">
        <h2 class="font-display text-5xl font-extrabold tracking-tight leading-tight">
          Control total desde tu{" "}
          <span class="text-secondary">Dashboard.</span>
        </h2>
        <p class="text-lg text-white/50 leading-relaxed">
          Visualizá cada aspecto de tu progreso. De la biometría profunda a la
          planificación táctica.
        </p>

        <ul class="space-y-6">
          {
            checkItems.map((item) => (
              <li class="flex items-center gap-6 group">
                <span
                  class="material-symbols-outlined text-secondary group-hover:scale-125 transition-transform"
                  style="font-variation-settings: 'FILL' 1;"
                >
                  check_circle
                </span>
                <span class="font-medium">{item}</span>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Right: Glass Dashboard Mockup -->
      <div class="relative reveal animate-float" style="animation-duration: 8s;">
        <div
          class="glass-card p-2 md:p-4 rotate-1 group hover:rotate-0 transition-transform duration-700 shadow-2xl"
        >
          <div class="bg-black/40 rounded-xl p-4 grid grid-cols-6 gap-2">
            <!-- Sidebar -->
            <div
              class="col-span-1 space-y-6 border-r border-white/5 pr-2 py-4"
            >
              <div class="w-6 h-6 bg-primary rounded"></div>
              <div class="w-6 h-1 bg-white/10 rounded"></div>
              <div class="w-6 h-1 bg-white/10 rounded"></div>
              <div class="w-6 h-1 bg-white/10 rounded"></div>
            </div>

            <!-- Main Content -->
            <div class="col-span-5 p-2 space-y-6">
              <div class="flex justify-between items-center">
                <div class="h-6 w-24 bg-white/5 rounded"></div>
                <div class="w-8 h-8 rounded-full bg-white/10"></div>
              </div>

              <div class="grid grid-cols-2 gap-4">
                <!-- Sleep widget -->
                <div class="glass-card p-3 h-24 flex flex-col justify-between">
                  <span class="text-[10px] uppercase opacity-40">Sueño</span>
                  <div class="text-lg font-bold">7.2h</div>
                  <div class="h-1 w-full bg-secondary/20 rounded overflow-hidden">
                    <div class="h-full w-3/4 bg-secondary rounded bar-grow">
                    </div>
                  </div>
                </div>

                <!-- Energy widget -->
                <div class="glass-card p-3 h-24 flex flex-col justify-between">
                  <span class="text-[10px] uppercase opacity-40">Energía</span>
                  <div class="text-lg font-bold">84%</div>
                  <div class="flex gap-1 h-8 items-end">
                    <div
                      class="w-1 h-3 bg-primary rounded-t bar-grow origin-bottom scale-y-0"
                      style="transition-delay: 0.1s;"
                    ></div>
                    <div
                      class="w-1 h-5 bg-primary rounded-t bar-grow origin-bottom scale-y-0"
                      style="transition-delay: 0.2s;"
                    ></div>
                    <div
                      class="w-1 h-8 bg-primary rounded-t bar-grow origin-bottom scale-y-0"
                      style="transition-delay: 0.3s;"
                    ></div>
                    <div
                      class="w-1 h-6 bg-primary rounded-t bar-grow origin-bottom scale-y-0"
                      style="transition-delay: 0.4s;"
                    ></div>
                  </div>
                </div>
              </div>

              <!-- Chart placeholder -->
              <div
                class="h-32 w-full bg-white/5 rounded-xl border border-white/5 flex items-center justify-center group-hover:bg-white/10 transition-colors"
              >
                <span
                  class="material-symbols-outlined opacity-20 text-4xl group-hover:scale-125 transition-transform"
                  >monitoring</span
                >
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>