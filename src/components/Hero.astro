---
---

<section class="relative min-h-[921px] flex items-center overflow-hidden pt-12">
  <canvas class="absolute inset-0 z-0 opacity-40" id="particleCanvas"></canvas>
  <div
    class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(0,191,255,0.1),transparent_70%)] opacity-50 z-[1]"
  >
  </div>

  <div
    class="max-w-7xl mx-auto px-6 grid md:grid-cols-2 gap-12 items-center relative z-10"
  >
    <!-- Left: Text Content -->
    <div class="space-y-8 reveal active">
      <div
        class="inline-flex items-center gap-2 px-4 py-1 rounded-full border border-primary/20 bg-primary/5 text-primary"
      >
        <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
        <span class="text-xs font-semibold tracking-widest uppercase"
          >Next Gen Performance</span
        >
      </div>

      <h1 class="font-display text-5xl md:text-6xl font-extrabold leading-tight tracking-tight">
        Organizá tu rendimiento. <br />
        <span class="text-gradient">Viví tu mejor versión.</span>
      </h1>

      <p class="text-lg text-white/50 max-w-lg leading-relaxed">
        La plataforma inteligente para atletas que redefine el entrenamiento a
        través de biometría en tiempo real y análisis predictivo.
      </p>

      <div class="flex flex-wrap gap-6 pt-4">
        <button
          class="px-8 py-4 bg-primary text-black font-semibold rounded-xl hover:scale-105 transition-all duration-300 shadow-[0_0_20px_rgba(143,214,255,0.2)] flex items-center gap-2"
        >
          Comenzar
          <span class="material-symbols-outlined">arrow_forward</span>
        </button>
        <button
          class="px-8 py-4 glass-card text-white font-semibold rounded-xl hover:bg-white/10 hover:scale-105 transition-all duration-300"
        >
          Conocer más
        </button>
      </div>
    </div>

    <!-- Right: Athlete Image -->
    <div class="relative group animate-float">
      <div
        class="absolute -inset-4 bg-primary/20 rounded-full blur-3xl opacity-20 group-hover:opacity-40 transition-opacity"
      >
      </div>
      <img
        src="https://lh3.googleusercontent.com/aida-public/AB6AXuAQS8z1xLe5vRPc6DTW9eWBnUSP9RD3P-TztncrEZntcgVz72LsU3fbK3TyGZ8oFmooHt340D3Jd6bhkDg0iu-SoboKJqf7Ch2UfDCev-iBiN51NHlgEtpYVi89kqQLrmgrYFn2vePSKYA6934cWWwB7nQFxCaO2Bcw324Qxzv67SdzPUdV9pY8h5Es92xEQfK0--hQBO6t95rHRUyhWp11-pHw4yH0VI9X3N7Q-tSPwTniI7C7oar85P5ZBChR3QsS0SvyF7s-pg"
        alt="Futuristic Athlete"
        class="relative rounded-2xl border border-white/10 shadow-2xl z-10 w-full object-cover aspect-[4/5] hover:border-primary/30 transition-all duration-700"
      />

      <!-- Readiness Badge -->
      <div
        class="absolute top-10 -right-4 glass-card p-3 z-20 animate-bounce hover:scale-110 transition-all duration-1000"
      >
        <div class="flex items-center gap-2 text-secondary">
          <span class="material-symbols-outlined">bolt</span>
          <span class="text-2xl font-bold">98%</span>
        </div>
        <p class="text-xs text-white/60">Readiness</p>
      </div>
    </div>
  </div>
</section>

<script>
  const canvas = document.getElementById("particleCanvas") as HTMLCanvasElement;
  if (canvas) {
    const ctx = canvas.getContext("2d")!;
    let particles: Particle[] = [];

    function resize() {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
    }
    window.addEventListener("resize", resize);
    resize();

    class Particle {
      x: number = 0;
      y: number = 0;
      size: number = 0;
      speedX: number = 0;
      speedY: number = 0;
      life: number = 0;

      constructor() {
        this.reset();
      }
      reset() {
        this.x = Math.random() * canvas.width;
        this.y = Math.random() * canvas.height;
        this.size = Math.random() * 1.5 + 0.5;
        this.speedX = (Math.random() - 0.5) * 0.5;
        this.speedY = (Math.random() - 0.5) * 0.5;
        this.life = Math.random() * 0.5 + 0.2;
      }
      update() {
        this.x += this.speedX;
        this.y += this.speedY;
        if (
          this.x < 0 ||
          this.x > canvas.width ||
          this.y < 0 ||
          this.y > canvas.height
        ) {
          this.reset();
        }
      }
      draw() {
        ctx.fillStyle = `rgba(143, 214, 255, ${this.life})`;
        ctx.beginPath();
        ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
        ctx.fill();
      }
    }

    for (let i = 0; i < 100; i++) {
      particles.push(new Particle());
    }

    function animateParticles() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      particles.forEach((p) => {
        p.update();
        p.draw();
      });
      requestAnimationFrame(animateParticles);
    }
    animateParticles();
  }
</script>