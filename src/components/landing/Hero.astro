---
---

<section class="relative min-h-screen flex items-center overflow-hidden pt-20">
  <!-- Particle canvas -->
  <canvas class="absolute inset-0 z-0 opacity-30" id="particleCanvas"></canvas>

  <!-- Radial glow -->
  <div class="absolute inset-0 z-0 pointer-events-none"
    style="background: radial-gradient(circle at 40% 50%, rgba(0,191,255,0.1), transparent 70%);">
  </div>

  <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-2 gap-16 items-center relative z-10 py-16">

    <!-- Left: Text -->
    <div class="space-y-8 reveal active">

      <!-- Pill -->
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-primary/20 bg-primary/5 text-primary">
        <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
        <span class="text-[11px] font-bold tracking-[0.15em] uppercase">Next Gen Performance</span>
      </div>

      <!-- Headline -->
      <h1 class="font-display font-extrabold tracking-tight leading-[1.05] text-5xl md:text-6xl">
        Organizá tu rendimiento.<br />
        <span class="text-gradient">Viví tu mejor versión.</span>
      </h1>

      <!-- Subtitle -->
      <p class="text-lg text-white/50 max-w-lg leading-relaxed">
        La plataforma inteligente para atletas que redefine el entrenamiento
        a través de biometría en tiempo real y análisis predictivo.
      </p>

      <!-- 3 roles -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 pt-2">
        <div class="space-y-1.5">
          <div class="flex items-center gap-2 text-primary font-semibold text-sm">
            <span class="material-symbols-outlined" style="font-size:16px;">fitness_center</span>
            Atletas
          </div>
          <p class="text-xs text-white/40 leading-relaxed">Organizá y optimizá tu rendimiento.</p>
        </div>
        <div class="space-y-1.5">
          <div class="flex items-center gap-2 text-secondary font-semibold text-sm">
            <span class="material-symbols-outlined" style="font-size:16px;">groups</span>
            Entrenadores
          </div>
          <p class="text-xs text-white/40 leading-relaxed">Gestioná equipos y prevení lesiones.</p>
        </div>
        <div class="space-y-1.5">
          <div class="flex items-center gap-2 text-tertiary font-semibold text-sm">
            <span class="material-symbols-outlined" style="font-size:16px;">family_restroom</span>
            Padres & Tutores
          </div>
          <p class="text-xs text-white/40 leading-relaxed">Acompañá el desarrollo deportivo.</p>
        </div>
      </div>

      <!-- CTAs -->
      <div class="flex flex-wrap gap-4 pt-2">
        <a
          href="/demo/registro"
          class="group flex items-center gap-2 px-8 py-4 bg-primary text-black font-bold rounded-xl text-sm tracking-wide hover:scale-105 active:scale-95 transition-all duration-300 shadow-[0_0_32px_rgba(143,214,255,0.3)]"
        >
          Comenzar
          <span class="material-symbols-outlined text-black group-hover:translate-x-0.5 transition-transform" style="font-size:18px;">arrow_forward</span>
        </a>
        <a
          href="#diferencial"
          class="flex items-center gap-2 px-8 py-4 glass-card text-white font-semibold rounded-xl text-sm hover:bg-white/10 hover:scale-105 transition-all duration-300"
        >
          Conocer más
        </a>
      </div>
    </div>

    <!-- Right: Image full -->
    <div class="relative group reveal" style="isolation: isolate;">
      <!-- Glow -->
      <div class="absolute -inset-6 bg-primary/15 rounded-3xl blur-3xl opacity-20 group-hover:opacity-35 transition-opacity duration-700" style="z-index: 0;"></div>

      <!-- Image -->
      <img
        src="https://lh3.googleusercontent.com/aida-public/AB6AXuAKuq1THsYnq_UGCtKh-G-Bf3F08GTHL2zkHAg7B-FVLE8pkmOMRJ39QWNwpRBDCa0I5KW0eRFhGRNLKavl5f6HSGjG3wR5BSsqD_4QHkpcNF_23I01vdfkh-mxAVzbsoxSVN0KQN-aG7KMUHL77Ttgo4_5QGCwvsu4QPkM4ETc6496JXPMBlcps6qj5gbciPg5U5mgRTUjsTEP7Q8TUt7Yk5i1OC-VRQFs4FY0-3nmm37BrE1e73NqzSbkBL0DosLU6nWG-Swkwg"
        alt="Atleta, entrenador y padre usando PULSO"
        style="position: relative; z-index: 1; width: 100%; height: 100%; min-height: 520px; max-height: 680px; object-fit: cover; object-position: center; border-radius: 16px; border: 1px solid rgba(255,255,255,0.1); box-shadow: 0 25px 50px rgba(0,0,0,0.5); display: block;"
      />

      <!-- Readiness badge -->
      <div
        style="position: absolute; top: 24px; right: -16px; z-index: 10;"
        class="glass-card px-4 py-3 shadow-xl"
      >
        <div class="flex items-center gap-2 text-secondary">
          <span class="material-symbols-outlined" style="font-size:18px;">bolt</span>
          <span class="font-display font-bold text-xl">98%</span>
        </div>
        <p class="text-[10px] text-white/40 mt-0.5">Readiness score</p>
      </div>

      <!-- Alert badge -->
      <div
        style="position: absolute; bottom: 24px; left: -16px; z-index: 10; background: rgba(239,68,68,0.08); border-color: rgba(239,68,68,0.2);"
        class="glass-card px-4 py-3 shadow-xl"
      >
        <div class="flex items-center gap-2 text-red-400 mb-1">
          <span class="material-symbols-outlined animate-pulse" style="font-size:14px;">warning</span>
          <span class="text-[10px] font-bold uppercase tracking-wider">Alerta</span>
        </div>
        <p class="text-xs text-white/60">Riesgo de sobrecarga hoy</p>
      </div>
    </div>

  </div>
</section>

<script>
  const canvas = document.getElementById("particleCanvas") as HTMLCanvasElement;
  if (canvas) {
    const ctx = canvas.getContext("2d")!;
    function resize() {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
    }
    window.addEventListener("resize", resize);
    resize();

    class Particle {
      x = Math.random() * canvas.width;
      y = Math.random() * canvas.height;
      size = Math.random() * 1.2 + 0.3;
      speedX = (Math.random() - 0.5) * 0.3;
      speedY = (Math.random() - 0.5) * 0.3;
      opacity = Math.random() * 0.35 + 0.1;
      update() {
        this.x += this.speedX;
        this.y += this.speedY;
        if (this.x < 0 || this.x > canvas.width) this.speedX *= -1;
        if (this.y < 0 || this.y > canvas.height) this.speedY *= -1;
      }
      draw() {
        ctx.fillStyle = `rgba(143, 214, 255, ${this.opacity})`;
        ctx.beginPath();
        ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
        ctx.fill();
      }
    }

    const particles = Array.from({ length: 80 }, () => new Particle());
    (function loop() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      particles.forEach((p) => { p.update(); p.draw(); });
      requestAnimationFrame(loop);
    })();
  }
</script>