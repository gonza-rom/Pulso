---
const testimonials = [
  {
    quote:
      "PULSO cambió radicalmente cómo gestiono mis cargas de entrenamiento. He evitado lesiones que antes eran constantes.",
    name: "Mateo Rivera",
    role: "Basquetbolista Elite",
    accent: "primary",
  },
  {
    quote:
      "Logré equilibrar mi último año de colegio con el torneo nacional. La agenda inteligente es clave.",
    name: "Sofía Castro",
    role: "Tenista Junior",
    accent: "secondary",
  },
];
---

<section class="py-24 bg-white/[0.02]">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid md:grid-cols-2 gap-6">
      {
        testimonials.map((t, i) => (
          <div
            class={`glass-card p-8 border-l-4 border-${t.accent} reveal`}
            style={`transition-delay: ${i * 200}ms`}
          >
            <p class="text-lg italic mb-8 text-white/90 leading-relaxed">
              "{t.quote}"
            </p>
            <div class="flex items-center gap-6">
              <div class="w-12 h-12 rounded-full bg-white/5 border border-white/10" />
              <div>
                <p class="font-bold">{t.name}</p>
                <p class="text-xs text-white/40 uppercase tracking-wider">
                  {t.role}
                </p>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>