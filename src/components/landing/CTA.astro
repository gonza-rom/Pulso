<section class="py-24 relative overflow-hidden">
  <div
    class="absolute inset-0 bg-primary/10 blur-[120px] rounded-full animate-pulse-slow"
  >
  </div>

  <div
    class="max-w-4xl mx-auto px-6 text-center relative z-10 space-y-8 reveal"
  >
    <h2 class="font-display text-5xl md:text-6xl font-extrabold tracking-tight">
      Tu rendimiento empieza hoy.
    </h2>
    <p class="text-lg text-white/60">
      Unite a la élite de atletas que ya están optimizando su futuro.
    </p>

    <div class="flex flex-col sm:flex-row gap-6 justify-center pt-6">
      <a
        href="/demo/registro"
        class="px-10 py-4 bg-primary text-black font-semibold rounded-xl hover:scale-105 active:scale-95 transition-all duration-300 shadow-[0_0_20px_rgba(143,214,255,0.2)]"
      >
        Crear Cuenta Gratis
      </a>
      <button
        class="px-10 py-4 glass-card font-semibold rounded-xl hover:bg-white/10 hover:scale-105 active:scale-95 transition-all duration-300"
      >
        Hablar con un Coach
      </button>
    </div>
  </div>
