---
---

<section class="py-24 bg-white/[0.02] overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 text-center mb-16 reveal">
    <h2 class="font-display text-4xl font-bold tracking-tight">
      Llevá tu rendimiento en el bolsillo
    </h2>
  </div>

  <div
    class="flex justify-center gap-6 px-6 overflow-x-auto pb-8 snap-x no-scrollbar"
  >
    <!-- Mobile Screen 1: Home -->
    <div
      class="min-w-[280px] h-[580px] bg-black rounded-[40px] border-[8px] border-white/10 overflow-hidden relative snap-center shadow-2xl reveal animate-float"
      style="animation-duration: 7s;"
    >
      <div class="p-6 space-y-6">
        <div class="flex justify-between items-center">
          <span class="font-display text-lg font-bold">PULSO</span>
          <span
            class="material-symbols-outlined hover:text-primary transition-colors cursor-pointer"
            >notifications</span
          >
        </div>

        <div class="space-y-4">
          <h4 class="text-xl font-bold">¡Hola, Juan!</h4>

          <div
            class="glass-card p-4 flex items-center justify-between group"
          >
            <div>
              <p class="text-[10px] opacity-40">Dormiste</p>
              <p class="text-lg font-bold">6.2 h</p>
            </div>
            <span
              class="material-symbols-outlined text-primary group-hover:rotate-12 transition-transform"
              >bedtime</span
            >
          </div>

          <div class="glass-card p-4 bg-red-500/10 border-red-500/20">
            <div class="flex items-center gap-2 text-red-400 mb-2">
              <span
                class="material-symbols-outlined text-sm animate-pulse"
                >warning</span
              >
              <span class="text-[10px] font-bold">ALERTA</span>
            </div>
            <p class="text-xs text-white/70">Riesgo de sobrecarga hoy.</p>
          </div>
        </div>

        <!-- Bottom Nav -->
        <div class="absolute bottom-4 left-0 w-full px-6">
          <div
            class="glass-card py-3 flex justify-around rounded-full bg-white/5"
          >
            <span class="material-symbols-outlined text-primary">home</span>
            <span
              class="material-symbols-outlined opacity-40 hover:opacity-100 transition-opacity"
              >calendar_today</span
            >
            <div
              class="w-10 h-10 -mt-8 rounded-full bg-primary flex items-center justify-center text-black shadow-lg hover:scale-110 active:scale-95 transition-all"
            >
              <span class="material-symbols-outlined">add</span>
            </div>
            <span
              class="material-symbols-outlined opacity-40 hover:opacity-100 transition-opacity"
              >bar_chart</span
            >
            <span
              class="material-symbols-outlined opacity-40 hover:opacity-100 transition-opacity"
              >person</span
            >
          </div>
        </div>
      </div>
    </div>

    <!-- Mobile Screen 2: Agenda -->
    <div
      class="min-w-[280px] h-[580px] bg-black rounded-[40px] border-[8px] border-white/10 overflow-hidden relative snap-center shadow-2xl reveal animate-float"
      style="animation-duration: 9s; transition-delay: 200ms;"
    >
      <div class="p-6 space-y-6">
        <div class="flex items-center gap-4">
          <span
            class="material-symbols-outlined hover:text-primary transition-colors cursor-pointer"
            >arrow_back</span
          >
          <h4 class="text-lg font-bold">Agenda</h4>
        </div>

        <div class="space-y-4">
          <!-- Monday -->
          <div class="flex gap-4 group">
            <div
              class="text-center opacity-40 group-hover:opacity-100 transition-opacity"
            >
              <p class="text-xs uppercase">Lun</p>
              <p class="text-lg">19</p>
            </div>
            <div
              class="flex-1 p-3 bg-secondary/10 border-l-4 border-secondary rounded hover:translate-x-1 transition-transform"
            >
              <p class="text-[10px] font-bold uppercase text-secondary">
                Entrenamiento
              </p>
              <p class="font-bold">Fuerza Tren Inferior</p>
              <p class="text-[10px] opacity-40">08:00 - 09:30</p>
            </div>
          </div>

          <!-- Tuesday -->
          <div class="flex gap-4 group">
            <div class="text-center">
              <p class="text-xs uppercase font-bold text-primary">Mar</p>
              <p class="text-lg font-bold text-primary">20</p>
            </div>
            <div
              class="flex-1 p-3 bg-primary/10 border-l-4 border-primary rounded hover:translate-x-1 transition-transform"
            >
              <p class="text-[10px] font-bold uppercase text-primary">
                Estudio
              </p>
              <p class="font-bold">Matemáticas Avanzadas</p>
              <p class="text-[10px] opacity-40">10:00 - 12:00</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>