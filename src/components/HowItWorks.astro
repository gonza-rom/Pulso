---
const steps = [
  {
    number: "1",
    title: "Organizá",
    desc: "Sincronizá tu vida académica y deportiva en un calendario dinámico.",
    accent: "primary",
  },
  {
    number: "2",
    title: "Analizá",
    desc: "Obtené insights profundos de cada entrenamiento y hora de descanso.",
    accent: "secondary",
  },
  {
    number: "3",
    title: "Mejorá",
    desc: "Evolucioná con recomendaciones de IA basadas en tus propios datos.",
    accent: "primary",
  },
];
---

<section class="py-24">
  <div class="max-w-7xl mx-auto px-6">
    <h2
      class="font-display text-4xl font-bold tracking-tight text-center mb-16 reveal"
    >
      EL CAMINO AL ÉXITO
    </h2>

    <div class="grid md:grid-cols-3 gap-16 relative">
      <!-- Connecting line -->
      <div
        class="hidden md:block absolute top-8 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-primary/30 to-transparent -z-10"
      >
      </div>

      {
        steps.map((step, i) => (
          <div
            class="text-center space-y-6 relative reveal"
            style={`transition-delay: ${i * 200}ms`}
          >
            <div
              class={`w-16 h-16 rounded-full bg-black border-2 border-${step.accent} mx-auto flex items-center justify-center font-display text-2xl text-${step.accent} z-10 relative hover:scale-110 transition-transform duration-500 cursor-default shadow-[0_0_20px_rgba(143,214,255,0.2)]`}
            >
              {step.number}
            </div>
            <h3 class="text-xl font-semibold">{step.title}</h3>
            <p class="text-white/50 leading-relaxed">{step.desc}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>