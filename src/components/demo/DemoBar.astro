---
export interface Props {
  current?: "login" | "atleta" | "entrenador" | "tutor" | "registro";
}
const { current } = Astro.props;

const items = [
  { id: "login",      label: "Login",          href: "/demo/login",      icon: "login" },
  { id: "atleta",     label: "Atleta",          href: "/demo/atleta",     icon: "sprint" },
  { id: "entrenador", label: "Entrenador",      href: "/demo/entrenador", icon: "sports" },
  { id: "tutor",      label: "Padres/Tutores",  href: "/demo/tutor",      icon: "family_restroom" },
  { id: "registro",   label: "Registro",        href: "/demo/registro",   icon: "person_add" },
];
---

<div
  class="fixed bottom-6 left-1/2 -translate-x-1/2 z-[999] flex items-center gap-1.5 px-3 py-2 rounded-2xl border border-amber-500/20 bg-black/80 backdrop-blur-2xl shadow-2xl shadow-black/60"
>
  <!-- Label demo -->
  <div class="flex items-center gap-1.5 pr-2.5 border-r border-white/10 mr-0.5 shrink-0">
    <span class="material-symbols-outlined text-amber-400" style="font-size:16px;">visibility</span>
    <span class="text-[10px] font-semibold text-amber-400 uppercase tracking-widest hidden sm:block">Demo</span>
  </div>

  <!-- Inicio -->
  <a
    href="/"
    class="flex items-center gap-1.5 px-2.5 py-1.5 rounded-xl text-[11px] font-medium text-white/40 hover:text-white hover:bg-white/[0.06] transition-all duration-150"
  >
    <span class="material-symbols-outlined" style="font-size:16px;">home</span>
    <span class="hidden sm:block">Inicio</span>
  </a>

  <div class="w-px h-4 bg-white/[0.08] shrink-0"></div>

  <!-- Interfaces -->
  {items.map(item => (
    <a
      href={item.href}
      class={`flex items-center gap-1.5 px-2.5 py-1.5 rounded-xl text-[11px] font-medium transition-all duration-150
        ${current === item.id
          ? "bg-amber-500/15 text-amber-400 border border-amber-500/25"
          : "text-white/40 hover:text-white hover:bg-white/[0.06]"
        }`}
    >
      <span class="material-symbols-outlined" style="font-size:16px;">{item.icon}</span>
      <span class="hidden sm:block">{item.label}</span>
    </a>
  ))}
</div>