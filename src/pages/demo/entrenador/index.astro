---
import Layout from "../../../layouts/Layout.astro";
import Sidebar from "../../../components/demo/Sidebar.astro";

const athletes = [
  { name: "Lucas Mendes",  pos: "Pivote / Dorsal 6",    readiness: 98,  load: "Media",  hrv: "78 ms", sleep: 4, color: "secondary" },
  { name: "Sofía Gento",   pos: "Extrema / Dorsal 7",   readiness: 72,  load: "Alta",   hrv: "52 ms", sleep: 3, color: "tertiary"  },
  { name: "Mateo Rivera",  pos: "Defensa / Dorsal 4",   readiness: 41,  load: "Crítica", hrv: "38 ms", sleep: 2, color: "error"     },
  { name: "Ana Villanueva",pos: "Delantera / Dorsal 9",  readiness: 85,  load: "Media",  hrv: "71 ms", sleep: 4, color: "primary"   },
];

const loadData = [40, 60, 85, 55, 100, 70, 45];
const days = ["Lun","Mar","Mié","Jue","Vie","Sáb","Dom"];
---

<Layout title="Dashboard Entrenador · PULSO" demo="entrenador" hideDemoOnMobile>
  <div class="flex min-h-screen">

    <Sidebar role="entrenador" current="dashboard" />

    <!-- HEADER MOBILE -->
    <header class="fixed top-0 left-0 w-full z-50 flex justify-between items-center px-6 h-16 bg-surface/40 backdrop-blur-xl border-b border-outline-variant/20 md:hidden">
      <span class="font-display text-xl font-extrabold tracking-tighter text-blue-400">PULSO</span>
      <div class="flex items-center gap-4">
        <span class="material-symbols-outlined text-blue-400">notifications</span>
        <div class="w-8 h-8 rounded-full bg-blue-400/20 border border-blue-400/30 flex items-center justify-center">
          <span class="material-symbols-outlined text-blue-400 text-[16px]">person</span>
        </div>
      </div>
    </header>

    <!-- MAIN -->
    <main class="md:ml-64 flex-1 pt-0 pb-28 md:pb-10 max-w-[1440px]">

      <!-- TOP BAR desktop -->
      <header class="sticky top-0 z-40 hidden md:flex justify-between items-center px-6 py-3 bg-background/60 backdrop-blur-md border-b border-white/5 shadow-[0_0_20px_rgba(143,214,255,0.08)]">
        <div>
          <h2 class="font-display font-bold text-blue-400 text-lg">Hola, Coach</h2>
          <p class="text-xs text-on-surface-variant">Equipo Elite Sub-23 · 24 Atletas activos</p>
        </div>
        <div class="flex items-center gap-4">
          <div class="relative">
            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant text-[18px]">search</span>
            <input
              type="text"
              placeholder="Buscar atleta..."
              class="bg-surface-container-low border-none rounded-full pl-10 pr-4 py-2 text-sm text-on-surface focus:ring-1 focus:ring-blue-400/40 w-56 outline-none transition-all"
            />
          </div>
          <button class="w-9 h-9 rounded-full bg-blue-400/20 border border-blue-400/30 flex items-center justify-center">
            <span class="material-symbols-outlined text-blue-400 text-[18px]">person</span>
          </button>
        </div>
      </header>

      <div class="p-6 space-y-6">

        <!-- KPI cards -->
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4">

          <div class="glass rounded-2xl p-5 flex flex-col justify-between">
            <div class="flex justify-between items-start">
              <p class="text-xs text-on-surface-variant uppercase tracking-wider">Predisposición Equipo</p>
              <span class="material-symbols-outlined text-secondary text-xl">show_chart</span>
            </div>
            <div class="mt-4">
              <span class="font-display text-4xl font-bold text-secondary">84%</span>
              <p class="text-xs text-secondary/60 mt-1">+2.4% vs ayer</p>
            </div>
          </div>

          <div class="glass rounded-2xl p-5 flex flex-col justify-between">
            <div class="flex justify-between items-start">
              <p class="text-xs text-on-surface-variant uppercase tracking-wider">Carga Semanal</p>
              <span class="material-symbols-outlined text-primary text-xl">fitness_center</span>
            </div>
            <div class="mt-4">
              <span class="font-display text-3xl font-bold text-primary">Óptima</span>
              <p class="text-xs text-primary/60 mt-1">Ratio ACWR: 1.12</p>
            </div>
          </div>

          <div class="glass rounded-2xl p-5 flex flex-col justify-between">
            <div class="flex justify-between items-start">
              <p class="text-xs text-on-surface-variant uppercase tracking-wider">Atletas Activos</p>
              <span class="material-symbols-outlined text-blue-400 text-xl">group</span>
            </div>
            <div class="mt-4">
              <span class="font-display text-4xl font-bold text-blue-400">21</span>
              <p class="text-xs text-on-surface-variant mt-1">3 en recuperación</p>
            </div>
          </div>

          <!-- Panel riesgo de lesión -->
          <div class="glass rounded-2xl p-5 border-l-4 border-error/50">
            <div class="flex justify-between items-center mb-3">
              <div class="flex items-center gap-2">
                <span class="material-symbols-outlined text-error text-xl" style="font-variation-settings:'FILL' 1;">warning</span>
                <h3 class="font-semibold text-on-surface text-sm">Riesgo Lesión</h3>
              </div>
              <span class="bg-error/10 text-error text-[10px] px-2 py-0.5 rounded-full font-bold">3 CRÍTICOS</span>
            </div>
            <div class="space-y-2">
              <div class="flex items-center justify-between p-2 bg-error/5 rounded-lg border border-error/10">
                <div>
                  <p class="text-xs font-bold text-on-surface">Mateo Rivera</p>
                  <p class="text-[9px] text-on-surface-variant uppercase">Fatiga del CNS elevada</p>
                </div>
                <button class="text-[10px] bg-error/20 hover:bg-error/40 text-error px-2 py-1 rounded-full transition-colors">Descanso</button>
              </div>
              <div class="flex items-center justify-between p-2 bg-error/5 rounded-lg border border-error/10 opacity-70">
                <div>
                  <p class="text-xs font-bold text-on-surface">Elena Soler</p>
                  <p class="text-[9px] text-on-surface-variant uppercase">Sobrecarga cuádriceps</p>
                </div>
                <button class="text-[10px] bg-error/20 hover:bg-error/40 text-error px-2 py-1 rounded-full transition-colors">Ajustar</button>
              </div>
            </div>
          </div>

        </div>

        <!-- Chart + AI widget -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

          <!-- Gráfico carga -->
          <div class="lg:col-span-2 glass rounded-2xl p-6 relative overflow-hidden">
            <div class="flex justify-between items-end mb-6">
              <div>
                <h3 class="font-display font-semibold text-on-surface text-lg">Carga de Entrenamiento</h3>
                <p class="text-xs text-on-surface-variant">Equipo vs. Promedio Individual · 7 días</p>
              </div>
              <div class="flex items-center gap-4">
                <div class="flex items-center gap-1.5">
                  <span class="w-2.5 h-2.5 rounded-full bg-primary"></span>
                  <span class="text-xs text-on-surface-variant">Equipo</span>
                </div>
                <div class="flex items-center gap-1.5">
                  <span class="w-2.5 h-2.5 rounded-full bg-secondary"></span>
                  <span class="text-xs text-on-surface-variant">Promedio</span>
                </div>
              </div>
            </div>

            <div class="h-52 w-full flex items-end gap-2 px-2 relative">
              {loadData.map((h, i) => (
                <div class="flex-1 flex flex-col items-center gap-1 h-full justify-end">
                  <div
                    class="w-full rounded-t-lg transition-all hover:brightness-125 relative group"
                    style={`height:${h}%; background: rgba(143,214,255,${0.15 + i * 0.07})`}
                  >
                    <div
                      class="absolute inset-x-0 bottom-0 bg-primary rounded-t-lg"
                      style={`height:${80 + Math.random() * 20}%; opacity: 0.7; ${h === 100 ? 'box-shadow: 0 0 12px rgba(143,214,255,0.4)' : ''}`}
                    ></div>
                  </div>
                  <span class="text-[9px] text-outline font-bold">{days[i]}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- PULSO AI -->
          <div class="glass rounded-2xl p-6 bg-gradient-to-br from-surface-container/40 to-blue-400/5">
            <div class="flex items-center gap-3 mb-5">
              <div class="p-2 bg-primary/20 rounded-xl">
                <span class="material-symbols-outlined text-primary text-xl" style="font-variation-settings:'FILL' 1;">psychology</span>
              </div>
              <h3 class="font-display font-semibold text-on-surface">PULSO AI</h3>
            </div>

            <div class="space-y-4">
              <div class="p-4 rounded-xl bg-white/5 border border-white/5">
                <p class="text-[10px] font-bold text-secondary uppercase mb-2 tracking-wider">Sesión Recomendada</p>
                <p class="text-sm text-on-surface-variant">Reducir intensidad de sprint en un <span class="text-secondary font-bold">15%</span> hoy. La variabilidad cardíaca grupal está un 4% por debajo de la línea base.</p>
              </div>

              <div class="p-4 rounded-xl bg-white/5 border border-white/5">
                <p class="text-[10px] font-bold text-primary uppercase mb-2 tracking-wider">Insights de Atletas</p>
                <ul class="space-y-2 text-sm text-on-surface-variant">
                  <li class="flex items-start gap-2">
                    <span class="material-symbols-outlined text-primary text-[14px] mt-0.5">circle</span>
                    <span>6 atletas con alta recuperación: sesión extra de potencia recomendada.</span>
                  </li>
                  <li class="flex items-start gap-2">
                    <span class="material-symbols-outlined text-primary text-[14px] mt-0.5">circle</span>
                    <span>Monitorizar hidratación: humedad del campo 85%.</span>
                  </li>
                </ul>
              </div>

              <button class="w-full py-3 rounded-xl border border-blue-400/30 text-blue-400 font-bold text-sm hover:bg-blue-400/10 transition-colors">
                Generar Plan de Sesión
              </button>
            </div>
          </div>

        </div>

        <!-- Tabla plantilla -->
        <div class="glass rounded-2xl overflow-hidden">
          <div class="p-6 flex justify-between items-center border-b border-white/5">
            <h3 class="font-display font-semibold text-on-surface text-lg">Estado de la Plantilla</h3>
            <div class="flex gap-1">
              {["Todos","Defensores","Atacantes"].map((tab, i) => (
                <button
                  class={`px-3 py-1.5 rounded-lg text-xs transition-colors ${i === 0 ? "bg-surface-container-highest text-primary" : "text-on-surface-variant hover:text-primary"}`}
                >
                  {tab}
                </button>
              ))}
            </div>
          </div>

          <div class="overflow-x-auto">
            <table class="w-full text-left">
              <thead class="bg-white/[0.03]">
                <tr>
                  {["Atleta","Readiness","Carga (S)","HRV","Sueño","Acciones"].map(h => (
                    <th class="px-6 py-3 text-xs text-on-surface-variant uppercase tracking-wider font-semibold">{h}</th>
                  ))}
                </tr>
              </thead>
              <tbody class="divide-y divide-white/5">
                {athletes.map((a) => (
                  <tr class="hover:bg-white/[0.03] transition-colors">

                    <!-- Nombre -->
                    <td class="px-6 py-4">
                      <div class="flex items-center gap-3">
                        <div class={`w-9 h-9 rounded-full bg-${a.color}/20 border border-${a.color}/30 flex items-center justify-center shrink-0`}>
                          <span class={`material-symbols-outlined text-${a.color} text-[16px]`}>person</span>
                        </div>
                        <div>
                          <p class="text-sm font-semibold text-on-surface">{a.name}</p>
                          <p class="text-[10px] text-on-surface-variant uppercase">{a.pos}</p>
                        </div>
                      </div>
                    </td>

                    <!-- Readiness -->
                    <td class="px-6 py-4">
                      <div class="flex items-center gap-2">
                        <div class="w-20 h-1.5 bg-surface-container-highest rounded-full overflow-hidden">
                          <div
                            class={`h-full rounded-full bg-${a.color}`}
                            style={`width:${a.readiness}%`}
                          ></div>
                        </div>
                        <span class={`text-sm font-bold text-${a.color}`}>{a.readiness}%</span>
                      </div>
                    </td>

                    <!-- Carga -->
                    <td class="px-6 py-4">
                      <span class={`text-xs px-2 py-1 rounded-full font-bold bg-${a.color}/10 text-${a.color}`}>
                        {a.load}
                      </span>
                    </td>

                    <!-- HRV -->
                    <td class="px-6 py-4 text-sm text-on-surface-variant">{a.hrv}</td>

                    <!-- Sueño (estrellas) -->
                    <td class="px-6 py-4">
                      <div class="flex gap-0.5">
                        {[1,2,3,4].map(s => (
                          <span
                            class={`material-symbols-outlined text-[14px] ${s <= a.sleep ? `text-${a.color}` : "text-surface-container-highest"}`}
                            style="font-variation-settings:'FILL' 1;"
                          >
                            star
                          </span>
                        ))}
                      </div>
                    </td>

                    <!-- Acciones -->
                    <td class="px-6 py-4">
                      <button class="text-on-surface-variant hover:text-primary transition-colors">
                        <span class="material-symbols-outlined text-[20px]">more_vert</span>
                      </button>
                    </td>

                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>

      </div>
    </main>

    <!-- NAV MOBILE INFERIOR -->
    <nav class="fixed bottom-0 w-full z-40 flex justify-around items-center px-4 py-3 bg-surface-container-high/80 backdrop-blur-xl border-t border-white/5 rounded-t-2xl md:hidden" style="padding-bottom: calc(0.75rem + env(safe-area-inset-bottom))">
      <a class="flex flex-col items-center text-blue-400 scale-110" href="#">
        <span class="material-symbols-outlined text-[22px]" style="font-variation-settings:'FILL' 1;">home</span>
        <span class="text-[9px] font-bold uppercase mt-0.5">Inicio</span>
      </a>
      <a class="flex flex-col items-center text-outline hover:text-blue-400 transition-all" href="/demo/entrenador/atletas">
        <span class="material-symbols-outlined text-[22px]">group</span>
        <span class="text-[9px] font-bold uppercase mt-0.5">Equipo</span>
      </a>
      <a class="flex flex-col items-center text-outline hover:text-blue-400 transition-all" href="#">
        <span class="material-symbols-outlined text-[22px]">monitoring</span>
        <span class="text-[9px] font-bold uppercase mt-0.5">Datos</span>
      </a>
      <a class="flex flex-col items-center text-outline hover:text-blue-400 transition-all" href="#">
        <span class="material-symbols-outlined text-[22px]">account_circle</span>
        <span class="text-[9px] font-bold uppercase mt-0.5">Perfil</span>
      </a>
    </nav>

  </div>
</Layout>