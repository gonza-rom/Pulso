---
import DemoBar from "../../components/demo/DemoBar.astro";
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Iniciar sesión · PULSO">

  <main class="min-h-screen flex items-center justify-center px-4 py-24 relative">

    <div
      class="absolute inset-0 pointer-events-none"
      style="background: radial-gradient(circle at 50% 40%, rgba(143,214,255,0.07), transparent 65%);"
    ></div>

    <div class="w-full max-w-md relative z-10">

      <!-- Logo -->
      <div class="text-center mb-10">
        <a href="/" class="inline-flex items-center gap-3 group">
          <span class="font-display text-xl font-extrabold tracking-tighter text-primary">PULSO</span>
        </a>
        <p class="mt-3 text-white/40 text-sm">Accedé a tu panel de rendimiento</p>
      </div>

      <!-- Card -->
      <div class="glass-card p-8">

        <!-- Google -->
        <button
          class="w-full flex items-center justify-center gap-3 py-3.5 rounded-xl border border-white/[0.10] bg-white/[0.04] text-white text-sm font-medium hover:bg-white/[0.08] hover:border-white/20 active:scale-[0.99] transition-all duration-150 mb-4"
        >
          <!-- Google SVG icon -->
          <svg width="18" height="18" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          Continuar con Google
        </button>

        <!-- Divider -->
        <div class="flex items-center gap-3 mb-5">
          <div class="flex-1 h-px bg-white/[0.06]"></div>
          <span class="text-[10px] text-white/70 uppercase tracking-wider">o con tu correo</span>
          <div class="flex-1 h-px bg-white/[0.06]"></div>
        </div>

        <!-- Email -->
        <div class="mb-4">
          <label class="block text-xs text-white/70 mb-1.5 font-medium">Correo electrónico</label>
          <div class="relative">
            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-white/60 text-[18px]">mail</span>
            <input
              type="email"
              placeholder="juan@email.com"
              class="w-full bg-white/[0.04] border border-white/[0.08] rounded-xl pl-10 pr-4 py-3 text-sm text-white placeholder:text-white/20 focus:outline-none focus:border-primary/40 focus:ring-1 focus:ring-primary/20 transition-all"
            />
          </div>
        </div>

        <!-- Contraseña -->
        <div class="mb-5">
          <label class="block text-xs text-white/70 mb-1.5 font-medium">Contraseña</label>
          <div class="relative">
            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-white/60 text-[18px]">lock</span>
            <input
              id="password-input"
              type="password"
              placeholder="Tu contraseña"
              class="w-full bg-white/[0.04] border border-white/[0.08] rounded-xl pl-10 pr-10 py-3 text-sm text-white placeholder:text-white/20 focus:outline-none focus:border-primary/40 focus:ring-1 focus:ring-primary/20 transition-all"
            />
            <button id="toggle-password" class="absolute right-3 top-1/2 -translate-y-1/2 text-white/20 hover:text-white/60 transition-colors">
              <span class="material-symbols-outlined text-[18px]">visibility</span>
            </button>
          </div>
        </div>

        <!-- Recordarme + olvidé -->
        <div class="flex items-center justify-between mb-6">
          <label class="flex items-center gap-2 cursor-pointer">
            <input
              type="checkbox"
              checked
              class="w-4 h-4 rounded border-white/20 bg-white/[0.04] text-primary focus:ring-primary/20 focus:ring-offset-0"
            />
            <span class="text-xs text-white/40">Recordarme</span>
          </label>
          <a href="#" class="text-xs text-primary hover:text-primary/80 transition-colors">¿Olvidaste tu contraseña?</a>
        </div>

        <!-- Botón ingresar -->
        <button
          id="login-btn"
          class="w-full flex items-center justify-center gap-2 py-3.5 rounded-xl bg-gradient-to-r from-primary to-primary/80 text-black font-bold text-sm neon-glow hover:scale-[1.01] active:scale-[0.99] transition-all duration-150"
        >
          <span class="material-symbols-outlined text-[18px]">login</span>
          Ingresar
        </button>

      </div>

      <!-- Pie -->
      <p class="text-center text-[11px] text-white/20 mt-6">
        ¿No tenés cuenta?
        <a href="registro" class="text-primary hover:underline ml-1">Registrate gratis</a>
      </p>

    </div>
  </main>
  <DemoBar />

</Layout>

<script>
  // Toggle password visibility
  const passwordInput = document.getElementById("password-input") as HTMLInputElement;
  document.getElementById("toggle-password")?.addEventListener("click", () => {
    const icon = document.querySelector("#toggle-password .material-symbols-outlined")!;
    if (passwordInput.type === "password") {
      passwordInput.type = "text";
      icon.textContent = "visibility_off";
    } else {
      passwordInput.type = "password";
      icon.textContent = "visibility";
    }
  });

  // Login → demo atleta por defecto
  document.getElementById("login-btn")?.addEventListener("click", () => {
    window.location.href = "/demo/atleta";
  });
</script>