---
import Layout from "../../../layouts/Layout.astro";
import Sidebar from "../../../components/demo/Sidebar.astro";
import DemoBar from "../../../components/demo/DemoBar.astro";

const topThree = [
  {
    pos: 2,
    name: "Marco V.",
    pts: "8,420",
    streak: "18d",
    multiplier: "x1.4",
    color: "on-surface-variant",
  },
  {
    pos: 1,
    name: "Sofia Reiss",
    pts: "12,850",
    streak: "34d",
    multiplier: "x2.0",
    color: "primary",
    champion: true,
  },
  {
    pos: 3,
    name: "Daniel K.",
    pts: "7,910",
    streak: "12d",
    multiplier: "x1.2",
    color: "tertiary",
  },
];

const rows = [
  { pos: 4,  name: "Julian Thorne", pts: "6,245", streak: "9d",  mult: "1.2x", badges: ["military_tech", "speed"] },
  { pos: 5,  name: "Elena Rossi",   pts: "5,910", streak: "15d", mult: "1.35x", badges: ["verified"] },
  { pos: 6,  name: "Kevin Wu",      pts: "5,820", streak: "5d",  mult: "1.1x",  badges: [] },
  { pos: 7,  name: "Ana Torres",    pts: "5,200", streak: "22d", mult: "1.5x",  badges: ["workspace_premium"] },
  { pos: 8,  name: "Riku Tanaka",   pts: "4,980", streak: "7d",  mult: "1.1x",  badges: [] },
  { pos: 9,  name: "Camila Bravo",  pts: "4,710", streak: "11d", mult: "1.2x",  badges: ["speed"] },
  { pos: 10, name: "Lars Müller",   pts: "4,430", streak: "3d",  mult: "1.05x", badges: [] },
];
---

<Layout title="Ranking Semanal · Atleta · PULSO">

  <div class="flex min-h-screen">

    <Sidebar role="atleta" current="ranking" />

    <!-- Header mobile -->
    <header class="fixed top-0 left-0 w-full z-50 flex justify-between items-center px-6 h-16 bg-surface/40 backdrop-blur-xl border-b border-white/10 md:hidden">
      <span class="font-display text-xl font-extrabold tracking-tighter text-primary">PULSO</span>
      <div class="flex items-center gap-4">
        <button class="text-on-surface-variant hover:text-secondary transition-colors">
          <span class="material-symbols-outlined">notifications</span>
        </button>
        <div class="w-8 h-8 rounded-full bg-primary/20 border border-primary/30 flex items-center justify-center">
          <span class="material-symbols-outlined text-primary text-[16px]">person</span>
        </div>
      </div>
    </header>

    <!-- Main -->
    <main class="md:ml-64 flex-1 pt-20 md:pt-10 pb-32 px-4 md:px-8 transition-all">

      <!-- Header de sección -->
      <header class="mb-8">
        <div class="flex items-center gap-2 text-primary mb-2">
          <span class="material-symbols-outlined text-[16px]">calendar_today</span>
          <span class="text-[10px] font-bold uppercase tracking-widest">Season 04</span>
        </div>
        <h1 class="font-display text-2xl md:text-3xl font-bold text-white">
          Ranking de la Comunidad
          <span class="text-primary-container"> — Semana 12</span>
        </h1>
        <p class="text-on-surface-variant text-sm mt-2 max-w-2xl">
          Medí tu desempeño frente a los mejores atletas de la región. Los multiplicadores de racha están activos.
        </p>
      </header>

      <!-- ===== PODIO TOP 3 ===== -->
      <section class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-10 items-end">

        <!-- 2° -->
        <div class="order-2 md:order-1 glass-card p-6 flex flex-col items-center text-center relative overflow-hidden group hover:-translate-y-1 transition-all duration-300">
          <div class="absolute top-0 right-0 px-2.5 py-1 bg-white/5 rounded-bl-xl text-[11px] font-bold text-on-surface-variant">#2</div>
          <div class="w-20 h-20 rounded-full border-2 border-white/20 p-0.5 mb-4 relative">
            <div class="w-full h-full rounded-full bg-surface-container-high flex items-center justify-center">
              <span class="material-symbols-outlined text-on-surface-variant text-3xl">person</span>
            </div>
            <div class="absolute -bottom-1 -right-1 bg-on-surface-variant text-black rounded-full w-6 h-6 flex items-center justify-center font-bold text-[10px]">2</div>
          </div>
          <h3 class="font-display font-semibold text-white text-lg">Marco V.</h3>
          <p class="text-secondary text-sm font-bold mt-0.5">8,420 PTS</p>
          <div class="mt-4 flex items-center gap-3 bg-black/40 rounded-full px-4 py-2 border border-white/[0.06]">
            <div class="flex items-center gap-1">
              <span class="material-symbols-outlined text-secondary text-[14px]" style="font-variation-settings:'FILL' 1;">local_fire_department</span>
              <span class="text-xs font-bold">18d</span>
            </div>
            <div class="w-px h-3 bg-white/10"></div>
            <span class="text-[10px] text-on-surface-variant">x1.4 XP</span>
          </div>
        </div>

        <!-- 1° -->
        <div class="order-1 md:order-2 glass-card md:-translate-y-5 p-6 md:p-8 flex flex-col items-center text-center relative overflow-hidden border border-primary/40 shadow-[0_0_40px_rgba(143,214,255,0.15)] bg-primary/5 hover:-translate-y-6 transition-all duration-300">
          <div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-primary to-transparent"></div>
          <div class="absolute -top-6 -left-6 w-20 h-20 bg-primary/20 blur-2xl rounded-full pointer-events-none"></div>
          <!-- partículas decorativas -->
          <div id="champion-card" class="w-28 h-28 rounded-full border-4 border-primary p-0.5 mb-4 relative shadow-[0_0_30px_rgba(143,214,255,0.4)]">
            <div class="w-full h-full rounded-full bg-surface-container-high flex items-center justify-center">
              <span class="material-symbols-outlined text-primary text-4xl">person</span>
            </div>
            <div class="absolute -bottom-2 left-1/2 -translate-x-1/2 bg-primary text-black rounded-full px-3 py-0.5 font-bold text-xs flex items-center gap-1 whitespace-nowrap shadow-lg">
              <span class="material-symbols-outlined text-[12px]" style="font-variation-settings:'FILL' 1;">star</span>
              1°
            </div>
          </div>
          <h3 class="font-display font-semibold text-white text-xl mt-2">Sofia Reiss</h3>
          <p class="text-primary font-bold text-xl mt-0.5">12,850 PTS</p>
          <div class="mt-4 flex items-center gap-4 bg-primary/10 rounded-full px-6 py-2 border border-primary/20">
            <div class="flex items-center gap-1">
              <span class="material-symbols-outlined text-secondary text-[16px]" style="font-variation-settings:'FILL' 1;">local_fire_department</span>
              <span class="text-sm font-bold">34d</span>
            </div>
            <div class="w-px h-4 bg-primary/20"></div>
            <span class="text-xs font-bold text-primary">x2.0 XP</span>
          </div>
        </div>

        <!-- 3° -->
        <div class="order-3 glass-card p-6 flex flex-col items-center text-center relative overflow-hidden hover:-translate-y-1 transition-all duration-300">
          <div class="absolute top-0 left-0 px-2.5 py-1 bg-tertiary/10 rounded-br-xl text-[11px] font-bold text-tertiary">#3</div>
          <div class="w-20 h-20 rounded-full border-2 border-tertiary/30 p-0.5 mb-4 relative">
            <div class="w-full h-full rounded-full bg-surface-container-high flex items-center justify-center">
              <span class="material-symbols-outlined text-tertiary text-3xl">person</span>
            </div>
            <div class="absolute -bottom-1 -right-1 bg-tertiary text-black rounded-full w-6 h-6 flex items-center justify-center font-bold text-[10px]">3</div>
          </div>
          <h3 class="font-display font-semibold text-white text-lg">Daniel K.</h3>
          <p class="text-secondary text-sm font-bold mt-0.5">7,910 PTS</p>
          <div class="mt-4 flex items-center gap-3 bg-black/40 rounded-full px-4 py-2 border border-white/[0.06]">
            <div class="flex items-center gap-1">
              <span class="material-symbols-outlined text-secondary text-[14px]" style="font-variation-settings:'FILL' 1;">local_fire_department</span>
              <span class="text-xs font-bold">12d</span>
            </div>
            <div class="w-px h-3 bg-white/10"></div>
            <span class="text-[10px] text-on-surface-variant">x1.2 XP</span>
          </div>
        </div>

      </section>

      <!-- ===== LISTA POSICIONES 4–10 ===== -->
      <section class="glass-card overflow-hidden mb-8">

        <!-- Cabecera tabla -->
        <div class="px-5 md:px-8 py-4 border-b border-white/[0.06] bg-white/[0.02] flex justify-between items-center">
          <h2 class="font-display font-semibold text-white text-base">Líderes de la Semana</h2>
          <span class="text-[10px] text-on-surface-variant uppercase tracking-widest hidden md:block">
            Actualizado hace 2 min
          </span>
        </div>

        <div class="divide-y divide-white/[0.05]">
          {rows.map(row => (
            <div class="flex items-center gap-3 md:gap-4 px-5 md:px-8 py-3.5 md:py-4 hover:bg-white/[0.03] transition-colors group">

              <!-- Posición -->
              <span class="w-7 shrink-0 font-display font-bold text-on-surface-variant text-sm">
                {String(row.pos).padStart(2, "0")}
              </span>

              <!-- Avatar -->
              <div class="w-9 h-9 md:w-10 md:h-10 rounded-full bg-surface-container-high border border-white/10 flex items-center justify-center shrink-0">
                <span class="material-symbols-outlined text-on-surface-variant text-[18px]">person</span>
              </div>

              <!-- Nombre + mobile stats -->
              <div class="flex-1 min-w-0">
                <p class="font-semibold text-white text-sm truncate">{row.name}</p>
                <div class="flex md:hidden items-center gap-2 text-[10px] text-on-surface-variant mt-0.5">
                  <span class="text-secondary font-bold">{row.mult}</span>
                  <span>·</span>
                  <span>{row.pts} pts</span>
                </div>
              </div>

              <!-- Streak (desktop) -->
              <div class="hidden md:flex flex-col items-end gap-0.5 pr-4 shrink-0">
                <div class="flex items-center gap-1 text-secondary">
                  <span class="material-symbols-outlined text-[13px]" style="font-variation-settings:'FILL' 1;">local_fire_department</span>
                  <span class="text-xs font-bold">{row.streak} racha</span>
                </div>
                <span class="text-[10px] text-on-surface-variant">Mult: {row.mult}</span>
              </div>

              <!-- Badges (desktop) -->
              <div class="hidden md:flex gap-1.5 shrink-0">
                {row.badges.map(icon => (
                  <span class="material-symbols-outlined text-primary/40 group-hover:text-primary/70 transition-colors text-[18px]">
                    {icon}
                  </span>
                ))}
              </div>

              <!-- Puntos -->
              <div class="text-right shrink-0">
                <span class="font-display font-bold text-white text-sm hidden md:block">{row.pts}</span>
                <span class="text-[9px] text-on-surface-variant hidden md:block">PTS</span>
                <!-- mobile: solo puntos grandes -->
                <span class="font-display font-bold text-white text-xs md:hidden">{row.pts}</span>
              </div>

            </div>
          ))}
        </div>

        <button class="w-full py-3.5 text-center text-primary/60 hover:text-primary text-[11px] font-bold uppercase tracking-widest transition-colors bg-white/[0.01] border-t border-white/[0.05]">
          Ver ranking completo (4–20)
        </button>

      </section>

      <!-- ===== INFO GAMIFICACIÓN ===== -->
      <section class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">

        <div class="glass-card p-5 border-l-4 border-secondary">
          <div class="flex gap-4 items-start">
            <span class="material-symbols-outlined text-secondary text-3xl shrink-0" style="font-variation-settings:'FILL' 1;">bolt</span>
            <div>
              <h4 class="font-display font-semibold text-white mb-1">Multiplicador de Racha</h4>
              <p class="text-on-surface-variant text-sm leading-relaxed">
                Tu racha de entrenamiento no es solo orgullo. Cada día consecutivo aumenta tu multiplicador de XP hasta
                <span class="text-secondary font-bold"> x2.0</span>. ¡No rompas el ciclo!
              </p>
            </div>
          </div>
        </div>

        <div class="glass-card p-5 border-l-4 border-primary">
          <div class="flex gap-4 items-start">
            <span class="material-symbols-outlined text-primary text-3xl shrink-0" style="font-variation-settings:'FILL' 1;">workspace_premium</span>
            <div>
              <h4 class="font-display font-semibold text-white mb-1">Recompensas Semanales</h4>
              <p class="text-on-surface-variant text-sm leading-relaxed">
                Terminar en el Top 10 otorga insignias exclusivas y acceso anticipado a los nuevos programas de
                entrenamiento de Élite.
              </p>
            </div>
          </div>
        </div>

      </section>

    </main>

    <!-- ===== BARRA FIJA INFERIOR — TU POSICIÓN ===== -->
    <div class="fixed bottom-0 inset-x-0 z-[60] bg-surface-container-highest/90 backdrop-blur-2xl border-t border-white/10 px-4 md:px-8 py-3 flex items-center justify-between gap-4"
         style="padding-bottom: calc(0.75rem + env(safe-area-inset-bottom))">

      <!-- Avatar + info -->
      <div class="flex items-center gap-3">
        <div class="relative shrink-0">
          <div class="w-10 h-10 md:w-12 md:h-12 rounded-full border-2 border-primary bg-primary/10 flex items-center justify-center">
            <span class="material-symbols-outlined text-primary text-[20px]">person</span>
          </div>
          <div class="absolute -bottom-1 -right-1 bg-primary text-black text-[9px] font-extrabold w-5 h-5 rounded-full flex items-center justify-center">14</div>
        </div>
        <div>
          <p class="font-semibold text-white text-sm">Vos — Alex Rios</p>
          <p class="text-xs text-on-surface-variant">
            <span class="text-primary font-bold">3,840 PTS</span>
            · Posición 14 de 2,400
          </p>
        </div>
      </div>

      <!-- Siguiente rango + CTA -->
      <div class="flex items-center gap-4">
        <div class="hidden lg:flex flex-col items-end">
          <span class="text-[10px] text-on-surface-variant uppercase font-bold tracking-tight">Siguiente rango</span>
          <span class="text-xs text-primary font-bold">+240 PTS para el 13°</span>
        </div>
        <button class="bg-gradient-to-r from-primary to-primary-container text-black px-4 md:px-6 py-2.5 rounded-xl font-display font-bold text-xs md:text-sm neon-glow hover:scale-105 active:scale-95 transition-all flex items-center gap-2 whitespace-nowrap">
          Subir de rango
          <span class="material-symbols-outlined text-[16px]">trending_up</span>
        </button>
      </div>

    </div>

    <!-- Nav mobile inferior -->
    <nav class="fixed bottom-16 w-full z-40 flex justify-around items-center px-4 py-2 bg-surface-container-lowest/90 backdrop-blur-xl border-t border-white/[0.05] md:hidden">
      <a class="flex flex-col items-center text-on-surface-variant hover:text-primary transition-all" href="/demo/atleta">
        <span class="material-symbols-outlined text-[22px]">home</span>
        <span class="text-[9px] font-bold uppercase mt-0.5">Inicio</span>
      </a>
      <a class="flex flex-col items-center text-on-surface-variant hover:text-primary transition-all" href="/demo/atleta/entrenamientos">
        <span class="material-symbols-outlined text-[22px]">fitness_center</span>
        <span class="text-[9px] font-bold uppercase mt-0.5">Entrenos</span>
      </a>
      <a class="flex flex-col items-center text-on-surface-variant hover:text-primary transition-all" href="/demo/atleta/agenda">
        <span class="material-symbols-outlined text-[22px]">calendar_today</span>
        <span class="text-[9px] font-bold uppercase mt-0.5">Agenda</span>
      </a>
      <a class="flex flex-col items-center text-primary" href="#">
        <span class="material-symbols-outlined text-[22px]" style="font-variation-settings:'FILL' 1;">leaderboard</span>
        <span class="text-[9px] font-bold uppercase mt-0.5">Ranking</span>
      </a>
      <a class="flex flex-col items-center text-on-surface-variant hover:text-primary transition-all" href="#">
        <span class="material-symbols-outlined text-[22px]">account_circle</span>
        <span class="text-[9px] font-bold uppercase mt-0.5">Perfil</span>
      </a>
    </nav>

  </div>

  <DemoBar current="atleta" />

</Layout>

<script>
  // Partículas sobre el 1° puesto
  const card = document.getElementById("champion-card");
  if (card) {
    const spawnParticle = () => {
      const p = document.createElement("div");
      Object.assign(p.style, {
        position: "absolute",
        width: "2px",
        height: "2px",
        background: "#8fd6ff",
        borderRadius: "50%",
        bottom: "100%",
        left: Math.random() * 100 + "%",
        opacity: "0.7",
        transition: "all 1.8s linear",
        pointerEvents: "none",
      });
      card.appendChild(p);
      requestAnimationFrame(() => {
        p.style.bottom = "120%";
        p.style.opacity = "0";
      });
      setTimeout(() => p.remove(), 1900);
    };
    setInterval(spawnParticle, 600);
  }

  // Hover lift en glass-card
  document.querySelectorAll<HTMLElement>(".glass-card").forEach((el) => {
    el.addEventListener("mouseenter", () => {
      if (!el.classList.contains("md:-translate-y-5")) {
        el.style.transform = "translateY(-4px)";
      }
    });
    el.addEventListener("mouseleave", () => {
      if (!el.classList.contains("md:-translate-y-5")) {
        el.style.transform = "";
      }
    });
  });
</script>