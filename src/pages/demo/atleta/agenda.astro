---
import Sidebar from "../../../components/demo/Sidebar.astro";
import DemoLayout from "../../../layouts/Layout.astro";

const days = [
  { short: "Lun", num: 14, today: false },
  { short: "Mar", num: 15, today: true },
  { short: "Mié", num: 16, today: false },
  { short: "Jue", num: 17, today: false },
  { short: "Vie", num: 18, today: false },
  { short: "Sáb", num: 19, today: false },
  { short: "Dom", num: 20, today: false },
];

const hours = ["07:00","08:00","09:00","10:00","11:00","12:00","13:00","14:00","15:00","16:00"];
---

<DemoLayout title="Agenda · Atleta" demo="atleta" hideDemoOnMobile>

  <div class="flex min-h-screen">
    <Sidebar role="atleta" current="agenda" />
    <!-- Header mobile -->
    <header class="fixed top-0 left-0 w-full z-50 flex justify-between items-center px-6 h-16 bg-surface/40 backdrop-blur-xl border-b border-outline-variant/20 md:hidden">
      <span class="font-display text-xl font-extrabold tracking-tighter text-primary">PULSO</span>
      <div class="flex items-center gap-4">
        <span class="material-symbols-outlined text-primary">notifications</span>
        <div class="w-8 h-8 rounded-full bg-primary/20 border border-primary/30 flex items-center justify-center">
          <span class="material-symbols-outlined text-primary text-[16px]">person</span>
        </div>
      </div>
    </header>

    <!-- Contenido principal -->
    <main class="md:ml-64 flex-1 pt-20 md:pt-10 pb-28 md:pb-20 px-6">

      <!-- Header de la agenda -->
      <header class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-8">
        <div>
          <h2 class="font-display text-3xl font-bold text-on-surface">Mi Agenda</h2>
          <p class="text-on-surface-variant text-sm mt-1">Semana del 14 al 20 de Mayo, 2024</p>
        </div>
        <div class="flex items-center gap-3">
          <div class="glass flex p-1 rounded-xl">
            <button class="p-2 hover:bg-white/5 rounded-lg transition-colors text-on-surface-variant">
              <span class="material-symbols-outlined text-[18px]">chevron_left</span>
            </button>
            <button class="px-4 py-1.5 hover:bg-white/5 rounded-lg transition-colors text-sm text-on-surface font-medium">Hoy</button>
            <button class="p-2 hover:bg-white/5 rounded-lg transition-colors text-on-surface-variant">
              <span class="material-symbols-outlined text-[18px]">chevron_right</span>
            </button>
          </div>
          <div class="glass flex items-center gap-2 px-3 py-2 rounded-xl">
            <span class="material-symbols-outlined text-primary text-[18px]">calendar_today</span>
            <span class="text-sm text-on-surface">Vista Semanal</span>
            <span class="material-symbols-outlined text-on-surface-variant text-[16px]">keyboard_arrow_down</span>
          </div>
        </div>
      </header>

      <!-- Vista MOBILE: tarjetas de eventos -->
      <div class="md:hidden space-y-3 mb-8">
        {days.map(d => (
          <div class={`glass rounded-2xl overflow-hidden ${d.today ? "border border-primary/30" : ""}`}>
            <div class={`px-4 py-2.5 flex items-center justify-between border-b border-white/5 ${d.today ? "bg-primary/5" : ""}`}>
              <span class={`text-xs font-bold uppercase tracking-wider ${d.today ? "text-primary" : "text-on-surface-variant"}`}>
                {d.today ? "Hoy · " : ""}{d.short} {d.num}
              </span>
              {d.today && <span class="w-2 h-2 bg-primary rounded-full animate-pulse"></span>}
            </div>
            {d.num === 15 && (
              <div class="p-3">
                <div class="bg-secondary/10 border-l-4 border-secondary rounded-xl p-3">
                  <span class="text-[10px] font-bold text-secondary uppercase tracking-wider">Entrenamiento</span>
                  <p class="text-sm font-semibold text-on-surface mt-0.5">Sesión HIIT Elite</p>
                  <div class="flex items-center gap-1 mt-1 text-outline text-[10px]">
                    <span class="material-symbols-outlined text-[12px]">schedule</span>
                    09:30 – 11:00
                  </div>
                </div>
              </div>
            )}
            {d.num === 14 && (
              <div class="p-3">
                <div class="bg-primary-container/10 border-l-4 border-primary-container rounded-xl p-3">
                  <span class="text-[10px] font-bold text-primary-container uppercase tracking-wider">Estudio</span>
                  <p class="text-sm font-semibold text-on-surface mt-0.5">Clase de Anatomía</p>
                  <div class="flex items-center gap-1 mt-1 text-outline text-[10px]">
                    <span class="material-symbols-outlined text-[12px]">schedule</span>
                    08:00 – 10:00
                  </div>
                </div>
              </div>
            )}
            {d.num === 18 && (
              <div class="p-3">
                <div class="bg-primary-container/10 border-l-4 border-primary-container rounded-xl p-3">
                  <span class="text-[10px] font-bold text-primary-container uppercase tracking-wider">Estudio</span>
                  <p class="text-sm font-semibold text-on-surface mt-0.5">Examen Fisiología</p>
                  <div class="flex items-center gap-1 mt-1 text-outline text-[10px]">
                    <span class="material-symbols-outlined text-[12px]">schedule</span>
                    08:00 – 12:00
                  </div>
                </div>
              </div>
            )}
            {![14,15,18].includes(d.num) && (
              <div class="px-4 py-3">
                <p class="text-xs text-outline">Sin eventos</p>
              </div>
            )}
          </div>
        ))}
      </div>

      <!-- Vista DESKTOP: grid calendario -->
      <div class="hidden md:block glass rounded-2xl overflow-hidden mb-6">
        <!-- Cabecera días -->
        <div class="grid grid-cols-8 border-b border-outline-variant/10 bg-white/[0.03]">
          <div class="p-4 border-r border-outline-variant/10"></div>
          {days.map(d => (
            <div class={`p-4 border-r last:border-0 border-outline-variant/10 text-center ${d.today ? "bg-primary/5" : ""}`}>
              <span class={`block text-[10px] font-bold uppercase tracking-wider ${d.today ? "text-primary" : "text-on-surface-variant"}`}>{d.short}</span>
              <span class={`text-xl font-display font-bold mt-0.5 ${d.today ? "text-primary" : "text-on-surface"}`}>{d.num}</span>
            </div>
          ))}
        </div>

        <!-- Cuerpo -->
        <div class="overflow-y-auto custom-scrollbar relative" style="max-height: 480px">
          <div class="grid grid-cols-8 min-h-full">
            <!-- Horas -->
            <div class="col-span-1 border-r border-outline-variant/10">
              {hours.map(h => (
                <div class="h-16 flex items-start justify-end pr-3 pt-2 text-[10px] text-outline font-bold">{h}</div>
              ))}
            </div>

            <!-- Días (7 columnas) -->
            <div class="col-span-7 grid grid-cols-7 relative">
              <!-- Líneas horizontales -->
              <div class="absolute inset-0 pointer-events-none" style="background-size: 100% 64px; background-image: linear-gradient(to bottom, rgba(255,255,255,0.04) 1px, transparent 1px)"></div>

              <!-- Divisores verticales -->
              {[...Array(7)].map((_, i) => (
                <div class={`${i === 1 ? "bg-primary/[0.02]" : ""} border-r last:border-0 border-outline-variant/5`}></div>
              ))}

              <!-- Eventos -->
              <!-- Lunes: Anatomía 08–10 = top 64px, h 128px -->
              <div class="absolute" style="top:64px; left:0%; width:14.28%; height:128px; padding:4px">
                <div class="h-full rounded-xl bg-primary-container/10 border-l-4 border-primary-container p-2.5 hover:scale-[1.02] transition-transform cursor-pointer">
                  <span class="block text-[9px] font-bold text-primary-container uppercase">Estudio</span>
                  <p class="text-xs font-semibold text-white mt-0.5">Clase de Anatomía</p>
                  <div class="flex items-center gap-1 mt-1.5 text-outline text-[10px]">
                    <span class="material-symbols-outlined text-[11px]">schedule</span>
                    08:00 – 10:00
                  </div>
                </div>
              </div>

              <!-- Martes: HIIT 09:30–11 = top 160px, h 96px -->
              <div class="absolute" style="top:160px; left:14.28%; width:14.28%; height:96px; padding:4px">
                <div class="h-full rounded-xl bg-secondary/10 border-l-4 border-secondary p-2.5 hover:scale-[1.02] transition-transform cursor-pointer shadow-[0_0_12px_rgba(112,223,49,0.15)]">
                  <span class="block text-[9px] font-bold text-secondary uppercase">Entrenamiento</span>
                  <p class="text-xs font-semibold text-white mt-0.5">Sesión HIIT Elite</p>
                  <div class="flex items-center gap-1 mt-1.5 text-outline text-[10px]">
                    <span class="material-symbols-outlined text-[11px]">schedule</span>
                    09:30 – 11:00
                  </div>
                </div>
              </div>

              <!-- Miércoles: Criofisio 15:00–16 = top 320px, h 64px -->
              <div class="absolute" style="top:320px; left:28.56%; width:14.28%; height:64px; padding:4px">
                <div class="h-full rounded-xl bg-white/5 border-l-4 border-outline p-2.5 hover:bg-white/10 transition-all cursor-pointer">
                  <span class="block text-[9px] font-bold text-on-surface-variant uppercase">Recuperación</span>
                  <p class="text-xs font-semibold text-white mt-0.5">Criofisioterapia</p>
                </div>
              </div>

              <!-- Viernes: Examen 08–12 = top 64px, h 192px -->
              <div class="absolute" style="top:64px; left:57.12%; width:14.28%; height:192px; padding:4px">
                <div class="h-full rounded-xl bg-primary-container/10 border-l-4 border-primary-container p-2.5 hover:scale-[1.02] transition-transform cursor-pointer">
                  <span class="block text-[9px] font-bold text-primary-container uppercase">Estudio</span>
                  <p class="text-xs font-semibold text-white mt-0.5">Examen Fisiología</p>
                  <p class="text-[10px] text-outline mt-1 leading-snug">Revisión de sistemas metabólicos.</p>
                </div>
              </div>

              <!-- Indicador hora actual -->
              <div class="absolute flex items-center pointer-events-none z-10" style="top:188px; left:0; width:100%">
                <div class="w-2.5 h-2.5 rounded-full bg-error border-2 border-surface shadow-[0_0_8px_rgba(255,180,171,0.5)]"></div>
                <div class="flex-1 h-[1.5px] bg-error/50"></div>
              </div>

            </div>
          </div>
        </div>
      </div>

      <!-- Resumen lateral solo desktop -->
      <div class="hidden md:grid grid-cols-3 gap-4">
        <div class="glass rounded-2xl p-5">
          <h4 class="text-xs text-on-surface-variant uppercase tracking-widest mb-4 opacity-70">Carga Semanal</h4>
          <div class="relative w-24 h-24 mx-auto mb-4">
            <svg class="w-full h-full -rotate-90" viewBox="0 0 96 96">
              <circle cx="48" cy="48" r="40" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="8"/>
              <circle cx="48" cy="48" r="40" fill="none" stroke="#70df31" stroke-width="8" stroke-dasharray="251.2" stroke-dashoffset="70" stroke-linecap="round"/>
            </svg>
            <div class="absolute inset-0 flex flex-col items-center justify-center">
              <span class="font-display text-2xl font-bold text-on-surface">72%</span>
              <span class="text-[9px] text-on-surface-variant uppercase">Meta</span>
            </div>
          </div>
          <ul class="space-y-2">
            {[
              ["#70df31","Entrenamiento","12h"],
              ["#00bfff","Estudio","24h"],
              ["#87929b","Descanso","8h"],
            ].map(([color, label, val]) => (
              <li class="flex items-center gap-2 text-xs">
                <span class="w-2 h-2 rounded-full shrink-0" style={`background:${color}`}></span>
                <span class="text-on-surface-variant flex-1">{label}</span>
                <span class="text-on-surface font-semibold">{val}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="glass rounded-2xl p-5 col-span-2">
          <h4 class="text-xs text-on-surface-variant uppercase tracking-widest mb-4 opacity-70">Próximo hito</h4>
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center shrink-0">
              <span class="material-symbols-outlined text-primary text-2xl">sprint</span>
            </div>
            <div>
              <p class="font-display font-semibold text-on-surface">Evaluación VO2 Max</p>
              <p class="text-xs text-on-surface-variant mt-0.5">Viernes 18, 17:00 · Centro de Rendimiento</p>
            </div>
          </div>
        </div>
      </div>

    </main>

    <!-- Nav mobile -->
    <nav class="fixed bottom-0 w-full z-40 flex justify-around items-center px-4 py-3 bg-surface-container-high/80 backdrop-blur-xl border-t border-white/5 rounded-t-2xl md:hidden" style="padding-bottom: calc(0.75rem + env(safe-area-inset-bottom))">
      <a class="flex flex-col items-center text-outline hover:text-primary transition-all" href="/demo/atleta">
        <span class="material-symbols-outlined text-[22px]">home</span>
        <span class="text-[9px] font-bold uppercase mt-0.5">Inicio</span>
      </a>
      <a class="flex flex-col items-center text-outline hover:text-primary transition-all" href="#">
        <span class="material-symbols-outlined text-[22px]">fitness_center</span>
        <span class="text-[9px] font-bold uppercase mt-0.5">Entrenos</span>
      </a>
      <a class="flex flex-col items-center text-primary scale-110" href="#">
        <span class="material-symbols-outlined text-[22px]" style="font-variation-settings:'FILL' 1;">calendar_today</span>
        <span class="text-[9px] font-bold uppercase mt-0.5">Agenda</span>
      </a>
      <a class="flex flex-col items-center text-outline relative hover:text-primary transition-all" href="#">
        <span class="material-symbols-outlined text-[22px]">error</span>
        <span class="text-[9px] font-bold uppercase mt-0.5">Alertas</span>
        <span class="absolute top-0 right-0 w-2 h-2 bg-error rounded-full border border-surface-container-high"></span>
      </a>
      <a class="flex flex-col items-center text-outline hover:text-primary transition-all" href="#">
        <span class="material-symbols-outlined text-[22px]">account_circle</span>
        <span class="text-[9px] font-bold uppercase mt-0.5">Perfil</span>
      </a>
    </nav>

  </div>

</DemoLayout>