---
import Layout from "../../../layouts/Layout.astro";
import Sidebar from "../../../components/demo/Sidebar.astro";
---

<Layout title="Dashboard Atleta" demo="atleta" hideDemoOnMobile>

  <div class="flex min-h-screen">
    <Sidebar role="atleta" current="dashboard" />
    <!-- ===== HEADER MOBILE ===== -->
    <header class="fixed top-0 left-0 w-full z-50 flex justify-between items-center px-6 h-16 bg-surface/40 backdrop-blur-xl border-b border-outline-variant/20 md:hidden">
      <span class="font-display text-xl font-extrabold tracking-tighter text-primary">PULSO</span>
      <div class="flex items-center gap-4">
        <span class="material-symbols-outlined text-primary">notifications</span>
        <div class="w-8 h-8 rounded-full bg-primary/20 border border-primary/30 flex items-center justify-center">
          <span class="material-symbols-outlined text-primary text-[16px]">person</span>
        </div>
      </div>
    </header>

    <!-- ===== MAIN CONTENT ===== -->
    <main class="md:ml-64 flex-1 pt-20 md:pt-10 pb-28 md:pb-20 px-6 transition-all">

      <!-- Bienvenida -->
      <header class="mb-8">
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-3">
          <div>
            <h1 class="font-display text-3xl font-bold text-on-surface">¡Hola, Alex! 👋</h1>
            <p class="text-on-surface-variant mt-1 text-sm">Hoy es un buen día para superar tus límites.</p>
          </div>
          <div class="glass px-4 py-2 rounded-full flex items-center gap-2 w-fit">
            <span class="w-2 h-2 bg-secondary rounded-full animate-pulse shadow-[0_0_8px_#70df31]"></span>
            <span class="text-xs text-secondary font-semibold">Sincronizado: hace 2 min</span>
          </div>
        </div>
      </header>

      <!-- Alerta de riesgo -->
      <section class="mb-8">
        <div class="glass rounded-2xl p-5 border-l-4 border-error">
          <div class="flex items-start gap-4">
            <div class="bg-error/15 p-2.5 rounded-xl shrink-0">
              <span class="material-symbols-outlined text-error text-2xl">report_problem</span>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="font-display font-semibold text-error text-lg">Riesgo de sobrecarga</h3>
              <p class="text-on-surface-variant text-sm mt-1">Dormiste menos de 6h y tu carga de entrenamiento es alta. Considerá reducir la intensidad de la sesión de hoy.</p>
              <button class="mt-3 text-error text-xs font-bold flex items-center gap-1 hover:gap-2 transition-all">
                Ver recomendaciones
                <span class="material-symbols-outlined text-[14px]">arrow_forward</span>
              </button>
            </div>
          </div>
        </div>
      </section>

      <!-- Métricas 2x2 / 4 en desktop -->
      <section class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
        <!-- Sueño -->
        <div class="glass rounded-2xl p-5 hover:border-primary/30 transition-all">
          <div class="flex justify-between items-start mb-3">
            <span class="material-symbols-outlined text-primary text-2xl">nights_stay</span>
            <span class="text-[10px] text-outline-variant uppercase tracking-wider">Objetivo 8h</span>
          </div>
          <p class="text-xs text-on-surface-variant uppercase tracking-wider mb-2">Horas de sueño</p>
          <div class="flex items-baseline gap-1">
            <span class="font-display text-4xl font-bold text-on-surface">6.2</span>
            <span class="text-lg text-primary">h</span>
            <span class="text-error text-xs font-bold ml-1">↓ 22%</span>
          </div>
          <div class="mt-3 w-full h-1 bg-surface-container-highest rounded-full overflow-hidden">
            <div class="bg-error h-full rounded-full" style="width: 77%"></div>
          </div>
        </div>

        <!-- Carga -->
        <div class="glass rounded-2xl p-5 hover:border-primary/30 transition-all">
          <div class="flex justify-between items-start mb-3">
            <span class="material-symbols-outlined text-primary-container text-2xl">fitness_center</span>
            <span class="bg-primary/10 text-primary text-[9px] px-2 py-0.5 rounded-md font-bold uppercase">Alta</span>
          </div>
          <p class="text-xs text-on-surface-variant uppercase tracking-wider mb-2">Carga de entrenamiento</p>
          <div class="flex items-baseline gap-1">
            <span class="font-display text-4xl font-bold text-on-surface">87</span>
            <span class="text-lg text-primary-container">%</span>
          </div>
          <div class="mt-3 w-full h-1 bg-surface-container-highest rounded-full overflow-hidden">
            <div class="bg-primary-container h-full rounded-full shadow-[0_0_8px_#00bfff]" style="width: 87%"></div>
          </div>
        </div>

        <!-- Energía -->
        <div class="glass rounded-2xl p-5 hover:border-primary/30 transition-all">
          <div class="flex justify-between items-start mb-3">
            <span class="material-symbols-outlined text-secondary text-2xl">bolt</span>
            <span class="bg-secondary/10 text-secondary text-[9px] px-2 py-0.5 rounded-md font-bold uppercase">Bueno</span>
          </div>
          <p class="text-xs text-on-surface-variant uppercase tracking-wider mb-2">Nivel de energía</p>
          <div class="flex items-baseline gap-1">
            <span class="font-display text-4xl font-bold text-on-surface">72</span>
            <span class="text-lg text-secondary">%</span>
          </div>
          <div class="mt-3 w-full h-1 bg-surface-container-highest rounded-full overflow-hidden">
            <div class="bg-secondary h-full rounded-full shadow-[0_0_8px_#70df31]" style="width: 72%"></div>
          </div>
        </div>

        <!-- Estado -->
        <div class="glass rounded-2xl p-5 hover:border-primary/30 transition-all">
          <div class="flex justify-between items-start mb-3">
            <span class="material-symbols-outlined text-tertiary text-2xl">monitor_heart</span>
          </div>
          <p class="text-xs text-on-surface-variant uppercase tracking-wider mb-2">Estado general</p>
          <div class="flex items-baseline gap-1">
            <span class="font-display text-2xl font-bold text-on-surface">Estable</span>
          </div>
          <div class="mt-3 flex gap-1 items-end h-8">
            <div class="flex-1 bg-tertiary/20 rounded-sm" style="height:40%"></div>
            <div class="flex-1 bg-tertiary/40 rounded-sm" style="height:60%"></div>
            <div class="flex-1 bg-tertiary/60 rounded-sm" style="height:80%"></div>
            <div class="flex-1 bg-tertiary   rounded-sm" style="height:90%"></div>
            <div class="flex-1 bg-tertiary/30 rounded-sm" style="height:50%"></div>
          </div>
        </div>
      </section>

      <!-- Gráfico semanal + próxima sesión -->
      <section class="grid grid-cols-1 lg:grid-cols-3 gap-4 mb-8">

        <!-- Gráfico -->
        <div class="lg:col-span-2 glass rounded-2xl p-6 min-h-[280px] flex flex-col">
          <div class="flex justify-between items-center mb-6">
            <div>
              <h3 class="font-display font-semibold text-on-surface text-lg">Carga Semanal</h3>
              <p class="text-xs text-on-surface-variant">Intensidad acumulada · últimos 7 días</p>
            </div>
            <select class="bg-surface-container-highest border-none text-on-surface rounded-lg text-xs py-1.5 px-3 focus:ring-1 focus:ring-primary">
              <option>Esta semana</option>
              <option>Mes pasado</option>
            </select>
          </div>
          <div class="flex-1 flex items-end gap-1.5 relative px-1 min-h-[140px]">
            <svg class="absolute inset-0 w-full h-full stroke-primary opacity-50" fill="none" preserveAspectRatio="none" viewBox="0 0 800 200">
              <path d="M0,180 Q100,170 150,120 T300,140 T450,60 T600,80 T800,20" stroke-linecap="round" stroke-width="2.5" filter="drop-shadow(0 0 6px #8fd6ff)"/>
              <path d="M0,180 Q100,170 150,120 T300,140 T450,60 T600,80 T800,20 V200 H0 Z" fill="url(#gc)" opacity="0.08"/>
              <defs>
                <linearGradient id="gc" x1="0" x2="0" y1="0" y2="1">
                  <stop offset="0%" stop-color="#8fd6ff"/>
                  <stop offset="100%" stop-color="#8fd6ff" stop-opacity="0"/>
                </linearGradient>
              </defs>
            </svg>
            <div class="w-full flex justify-between absolute bottom-0 left-0 px-1">
              {["Lun","Mar","Mié","Jue","Vie","Sáb","Dom"].map(d => (
                <span class="text-[9px] text-outline font-bold">{d}</span>
              ))}
            </div>
          </div>
        </div>

        <!-- Próxima sesión -->
        <div class="glass rounded-2xl p-6">
          <h3 class="text-xs text-on-surface-variant uppercase tracking-widest mb-5 opacity-70">Próxima Sesión</h3>
          <div class="flex items-center gap-4 mb-5">
            <div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center text-primary shrink-0">
              <span class="material-symbols-outlined text-3xl">sprint</span>
            </div>
            <div>
              <p class="font-display font-semibold text-on-surface">Series 400m</p>
              <p class="text-xs text-on-surface-variant">Hoy, 18:30 · Estadio</p>
            </div>
          </div>
          <div class="space-y-2">
            {[
              ["Series", "12 × 400m"],
              ["Recuperación", "60s pasiva"],
              ["Intensidad", "Z4 – Umbral"],
            ].map(([k, v]) => (
              <div class="flex justify-between text-xs py-2 border-b border-white/5 last:border-0">
                <span class="text-on-surface-variant">{k}</span>
                <span class="text-on-surface font-semibold">{v}</span>
              </div>
            ))}
          </div>
        </div>

      </section>

      <!-- Insights bento -->
      <section class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="glass rounded-2xl p-5 border-t-2 border-secondary/30">
          <div class="flex items-center gap-2 mb-3">
            <span class="material-symbols-outlined text-secondary text-xl">insights</span>
            <h4 class="text-xs font-bold text-on-surface uppercase tracking-wider">Insight Nutricional</h4>
          </div>
          <p class="text-on-surface-variant text-sm">Hidratación óptima (82%). Mantené el consumo de electrolitos después de la sesión intensa.</p>
        </div>
        <div class="glass rounded-2xl p-5 border-t-2 border-primary/30">
          <div class="flex items-center gap-2 mb-3">
            <span class="material-symbols-outlined text-primary text-xl">psychology</span>
            <h4 class="text-xs font-bold text-on-surface uppercase tracking-wider">Enfoque Mental</h4>
          </div>
          <p class="text-on-surface-variant text-sm">Tu HRV indica que tu sistema nervioso está preparado para carga moderada.</p>
        </div>
        <div class="glass rounded-2xl p-5 border-t-2 border-tertiary/30">
          <div class="flex items-center gap-2 mb-3">
            <span class="material-symbols-outlined text-tertiary text-xl">military_tech</span>
            <h4 class="text-xs font-bold text-on-surface uppercase tracking-wider">Logro Reciente</h4>
          </div>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-tertiary/10 flex items-center justify-center shrink-0">
              <span class="material-symbols-outlined text-tertiary text-lg">workspace_premium</span>
            </div>
            <p class="text-on-surface-variant text-sm">¡Nueva marca personal en 10km! Bajaste 12 segundos.</p>
          </div>
        </div>
      </section>

    </main>

    <!-- ===== NAV MOBILE INFERIOR ===== -->
    <nav class="fixed bottom-0 w-full z-40 flex justify-around items-center px-4 py-3 bg-surface-container-high/80 backdrop-blur-xl border-t border-white/5 rounded-t-2xl md:hidden" style="padding-bottom: calc(0.75rem + env(safe-area-inset-bottom))">
      <a class="flex flex-col items-center text-primary scale-110" href="#">
        <span class="material-symbols-outlined text-[22px]" style="font-variation-settings:'FILL' 1;">home</span>
        <span class="text-[9px] font-bold uppercase mt-0.5">Inicio</span>
      </a>
      <a class="flex flex-col items-center text-outline hover:text-primary transition-all" href="/demo/atleta/entrenamientos">
        <span class="material-symbols-outlined text-[22px]">fitness_center</span>
        <span class="text-[9px] font-bold uppercase mt-0.5">Entrenos</span>
      </a>
      <a class="flex flex-col items-center text-outline hover:text-primary transition-all" href="/demo/atleta/agenda">
        <span class="material-symbols-outlined text-[22px]">calendar_today</span>
        <span class="text-[9px] font-bold uppercase mt-0.5">Agenda</span>
      </a>
      <a class="flex flex-col items-center text-outline hover:text-primary transition-all relative" href="#">
        <span class="material-symbols-outlined text-[22px]">error</span>
        <span class="text-[9px] font-bold uppercase mt-0.5">Alertas</span>
        <span class="absolute top-0 right-1 w-2 h-2 bg-error rounded-full border border-surface-container-high"></span>
      </a>
      <a class="flex flex-col items-center text-outline hover:text-primary transition-all" href="#">
        <span class="material-symbols-outlined text-[22px]">account_circle</span>
        <span class="text-[9px] font-bold uppercase mt-0.5">Perfil</span>
      </a>
    </nav>

  </div>

</DemoLayout>

<script>
  document.querySelectorAll(".glass").forEach((card) => {
    card.addEventListener("mousemove", (e: Event) => {
      const me = e as MouseEvent;
      const rect = (card as HTMLElement).getBoundingClientRect();
      const x = me.clientX - rect.left;
      const y = me.clientY - rect.top;
      (card as HTMLElement).style.background = `radial-gradient(400px circle at ${x}px ${y}px, rgba(255,255,255,0.06), transparent), rgba(255,255,255,0.04)`;
    });
    card.addEventListener("mouseleave", () => {
      (card as HTMLElement).style.background = "rgba(255, 255, 255, 0.04)";
    });
  });
</script>